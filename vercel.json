{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/scan",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/remind",
      "schedule": "0 12 * * *"
    }
  ]
}